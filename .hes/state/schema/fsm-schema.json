{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hes-fsm-schema-v1",
  "title": "HES Finite State Machine Schema",
  "description": "Schema for HES v3.4 Deterministic Skill Engine state management",
  "version": "1.0.0",

  "definitions": {
    "PhaseState": {
      "type": "string",
      "enum": ["ZERO", "DISCOVERY", "SPEC", "DESIGN", "DATA", "RED", "GREEN", "REVIEW", "DONE"],
      "description": "Valid phases in the HES workflow"
    },

    "ProjectState": {
      "type": "string",
      "enum": ["ZERO", "ORPHAN", "LEGACY", "ACTIVE"],
      "description": "Project-level bootstrap states"
    },

    "Transition": {
      "type": "object",
      "required": ["from", "to", "gate"],
      "properties": {
        "from": { "$ref": "#/definitions/PhaseState" },
        "to": { "$ref": "#/definitions/PhaseState" },
        "gate": {
          "type": "string",
          "description": "Required condition for transition"
        },
        "skill": {
          "type": "string",
          "description": "Skill file to execute during transition"
        }
      }
    }
  },

  "type": "object",
  "required": ["version", "current_state", "active_skill", "allowed_transitions", "context_refs", "last_validated_at"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Schema version (major.minor)",
      "default": "1.0"
    },

    "project_state": {
      "$ref": "#/definitions/ProjectState",
      "default": "ZERO"
    },

    "current_state": {
      "$ref": "#/definitions/PhaseState",
      "description": "Current phase in the workflow"
    },

    "active_skill": {
      "type": ["string", "null"],
      "description": "Path to the currently active skill file",
      "pattern": "^skills/[0-9]{2}-[a-z-]+\\.md$"
    },

    "allowed_transitions": {
      "type": "array",
      "items": { "$ref": "#/definitions/PhaseState" },
      "description": "Valid next states from current state"
    },

    "context_refs": {
      "type": "object",
      "properties": {
        "include": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Files to include in context"
        },
        "exclude": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Files to exclude from context"
        }
      },
      "default": { "include": [], "exclude": [] }
    },

    "last_validated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last validation"
    },

    "validation_checksum": {
      "type": ["string", "null"],
      "description": "Checksum of last valid state"
    },

    "feature_context": {
      "type": "object",
      "properties": {
        "active_feature": {
          "type": ["string", "null"],
          "description": "Currently active feature name"
        },
        "features": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/PhaseState" },
          "description": "Map of feature names to their states"
        },
        "dependency_graph": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          },
          "description": "Feature dependencies"
        }
      }
    },

    "project_metadata": {
      "type": "object",
      "properties": {
        "project": { "type": "string" },
        "stack": { "type": "string" },
        "ide": { "type": "string" },
        "domains": { "type": "array", "items": { "type": "string" } },
        "harness_version": { "type": "string" },
        "agent_model": { "type": "string" },
        "user_language": { "type": "string" },
        "audience_mode": { "type": "string" },
        "completed_cycles": { "type": "integer" }
      }
    },

    "session": {
      "type": "object",
      "properties": {
        "checkpoint": { "type": ["string", "null"] },
        "phase_lock": { "type": ["string", "null"] },
        "messages_in_session": { "type": "integer" }
      }
    },

    "installation": {
      "type": "object"
    },

    "last_updated": {
      "type": "string",
      "format": "date-time"
    }
  },

  "transition_rules": {
    "ZERO": { "allowed_next": ["DISCOVERY"], "gate": null },
    "DISCOVERY": { "allowed_next": ["SPEC"], "gate": "br_list_approved" },
    "SPEC": { "allowed_next": ["DESIGN"], "gate": "bdd_scenarios_approved" },
    "DESIGN": { "allowed_next": ["DATA"], "gate": "adrs_approved" },
    "DATA": { "allowed_next": ["RED"], "gate": "migrations_reviewed" },
    "RED": { "allowed_next": ["GREEN"], "gate": "failing_test_exists" },
    "GREEN": { "allowed_next": ["REVIEW"], "gate": "tests_passing" },
    "REVIEW": { "allowed_next": ["DONE"], "gate": "review_checklist_complete" },
    "DONE": { "allowed_next": [], "gate": null }
  }
}
