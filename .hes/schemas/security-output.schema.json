  "artifacts_required": [
    ".hes/state/security-report-final.json",
    ".hes/state/security-exceptions.json"
  ],
  "gate_fields": {
    "high_findings": { "operator": "==", "value": 0 },
    "gate_passed": { "operator": "==", "value": true }
